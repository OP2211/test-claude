{
  "name": "football-fan-chat",
  "version": "1.0.0",
  "description": "Matchday football fan chat app",
  "private": true,
  "scripts": {
    "dev": "vercel dev",
    "build": "cd client && npm install && npm run build",
    "install:all": "npm install --prefix api && npm install --prefix client",
    "dev:legacy": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "npm run dev --prefix server",
    "dev:client": "npm start --prefix client"
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
