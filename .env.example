# ── Pusher (real-time WebSocket) ─────────────────────────────────────────────
# Create a free account at https://pusher.com → Channels → Create app

PUSHER_APP_ID=your_app_id
PUSHER_KEY=your_key
PUSHER_SECRET=your_secret
PUSHER_CLUSTER=eu

# ── Google (for authentication) ──────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ── NextAuth (authentication helper) ─────────────────────────────────────────
# For local dev: http://localhost:3000
# Authorized Redirect URI in Google Console: http://localhost:3000/api/auth/callback/google
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=any_random_string_for_local_dev

# ── Public env vars (exposed to browser via Next.js) ────────────────────────
NEXT_PUBLIC_PUSHER_KEY=your_key        # same as PUSHER_KEY above
NEXT_PUBLIC_PUSHER_CLUSTER=eu          # same as PUSHER_CLUSTER above

# ── Supabase (chat persistence + profiles) ───────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key
# Required for server-side writes/reads in API routes.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Google Tag Manager (leave empty or unset to disable)
NEXT_PUBLIC_GTM_ID=

# ── Waitlist (default: FormSubmit via /api/waitlist) ──────────────────────────
# WAITLIST_NOTIFICATION_EMAIL=you@gmail.com   # MUST match the inbox where you clicked FormSubmit’s “Activate Form” (each address is a separate form)
# NEXTAUTH_URL=http://localhost:3000          # or NEXT_PUBLIC_APP_URL — required for FormSubmit from the server
# First time: open that inbox (and Spam), click FormSubmit’s “Activate Form”, then retry.
#
# Optional Web3Forms (browser): only used if BOTH are set:
# NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=your_key
# NEXT_PUBLIC_WAITLIST_USE_WEB3FORMS=true
