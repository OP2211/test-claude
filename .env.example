# ── Pusher (real-time WebSocket) ─────────────────────────────────────────────
# Create a free account at https://pusher.com → Channels → Create app
# Select "React" as frontend and "Node.js" as backend

PUSHER_APP_ID=your_app_id
PUSHER_KEY=your_key
PUSHER_SECRET=your_secret
PUSHER_CLUSTER=eu          # e.g. eu, us2, ap2 — match the cluster you chose

# ── React client env vars (prefix with REACT_APP_) ───────────────────────────
# Copy PUSHER_KEY and PUSHER_CLUSTER here for the browser bundle

REACT_APP_PUSHER_KEY=your_key       # same as PUSHER_KEY above
REACT_APP_PUSHER_CLUSTER=eu         # same as PUSHER_CLUSTER above

# ── Local dev only ────────────────────────────────────────────────────────────
# The React dev server proxies /api/* to the local Vercel dev server automatically.
# Run: vercel dev   (starts both the API and the React dev server)
