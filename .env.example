# ── Pusher (real-time WebSocket) ─────────────────────────────────────────────
# Create a free account at https://pusher.com → Channels → Create app

PUSHER_APP_ID=your_app_id
PUSHER_KEY=your_key
PUSHER_SECRET=your_secret
PUSHER_CLUSTER=eu

# ── Public env vars (exposed to browser via Next.js) ────────────────────────
NEXT_PUBLIC_PUSHER_KEY=your_key        # same as PUSHER_KEY above
NEXT_PUBLIC_PUSHER_CLUSTER=eu          # same as PUSHER_CLUSTER above
